# Step 1: Read the number of integers (n is given but not strictly needed for the logic)
n = int(input())

# Step 2: Read the list of integers
arr = input().split()

# Step 3: Check conditions
# Condition 1: Check if all elements are positive
# Condition 2: Check if any element is a palindrome (string == string reversed)
all_positive = all(int(i) > 0 for i in arr)
any_palindrome = any(i == i[::-1] for i in arr)

# Step 4: Print True if both are satisfied, otherwise False
print(all_positive and any_palindrome)
