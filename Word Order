from collections import OrderedDict

if __name__ == '__main__':
    n = int(input())
    word_counts = OrderedDict()
    
    for _ in range(n):
        word = input().strip()
        # Increment count if word exists, otherwise initialize to 1
        if word in word_counts:
            word_counts[word] += 1
        else:
            word_counts[word] = 1
            
    # Step 1: Print total number of distinct words
    print(len(word_counts))
    
    # Step 2: Print occurrences in order of first appearance
    # Using the unpacking operator * to print values separated by space
    print(*(word_counts.values()))
