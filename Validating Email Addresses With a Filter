import re

def fun(s):
    # Validating email using the specific HackerRank rules:
    # 1. username@websitename.extension
    # 2. username: letters, digits, dashes, and underscores
    # 3. website: letters and digits
    # 4. extension: letters, max length 3
    try:
        # Split into username and the rest
        username, rest = s.split('@')
        # Split rest into website and extension
        website, extension = rest.split('.')
    except ValueError:
        # Fails if there isn't exactly one '@' or one '.' in the right places
        return False

    # Check for empty fields
    if not username or not website or not extension:
        return False
    
    # Validate each part
    # Username: only alphanumeric, -, and _
    if not all(c.isalnum() or c in '-_' for c in username):
        return False
    
    # Website: only alphanumeric
    if not website.isalnum():
        return False
    
    # Extension: only letters, length 1-3
    if not (extension.isalpha() and 0 < len(extension) <= 3):
        return False
        
    return True


