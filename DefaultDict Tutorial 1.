from collections import defaultdict

if __name__ == '__main__':
    # Read n and m
    n, m = map(int, input().split())
    
    # Initialize defaultdict with a list factory
    group_a = defaultdict(list)
    
    # Store indices of words in Group A (1-indexed)
    for i in range(1, n + 1):
        word = input()
        group_a[word].append(i)
        
    # Check words in Group B
    for _ in range(m):
        word_b = input()
        if word_b in group_a:
            # Print all indices separated by a space
            print(*(group_a[word_b]))
        else:
            # Word not found in Group A
            print("-1")
