import math

# Read the lengths of sides AB and BC
ab = int(input())
bc = int(input())

# Calculate the angle in radians using atan2(opposite, adjacent)
# atan2 is safer as it handles division by zero automatically
angle_rad = math.atan2(ab, bc)

# Convert radians to degrees
angle_deg = math.degrees(angle_rad)

# Round to the nearest integer and print with the degree symbol
# Using chr(176) for the '°' symbol
print(f"{round(angle_deg)}{chr(176)}")
