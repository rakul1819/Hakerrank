import re
import sys

def check_regex():
    # Read all input at once and split by whitespace/newlines
    data = sys.stdin.read().splitlines()
    
    if not data:
        return
        
    # First line is the number of test cases
    try:
        t = int(data[0])
    except (ValueError, IndexError):
        return

    # Process each subsequent line as a regex string
    for i in range(1, t + 1):
        try:
            re.compile(data[i])
            print("True")
        except (re.error, IndexError):
            print("False")

if __name__ == "__main__":
    check_regex()
