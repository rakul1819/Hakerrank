if __name__ == '__main__':
    # Step 1: Read N (rows) and M (columns)
    n, m = map(int, input().split())
    
    # Step 2: Read the spreadsheet data into a list of lists
    arr = []
    for _ in range(n):
        arr.append(list(map(int, input().split())))
    
    # Step 3: Read the index K to sort by
    k = int(input())
    
    # Step 4: Sort the array in-place based on the Kth attribute
    # arr[k] refers to the value at index K of each sublist
    arr.sort(key=lambda x: x[k])
    
    # Step 5: Print the resulting table
    for row in arr:
        print(*row)
