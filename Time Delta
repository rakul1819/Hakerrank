from datetime import datetime

# Define the input format string
fmt = '%a %d %b %Y %H:%M:%S %z'

for _ in range(int(input())):
    # Parse the two timestamp strings into datetime objects
    t1 = datetime.strptime(input(), fmt)
    t2 = datetime.strptime(input(), fmt)
    
    # Calculate the absolute difference in seconds
    # .total_seconds() returns a float, so we convert to int
    diff = int(abs((t1 - t2).total_seconds()))
    print(diff)
