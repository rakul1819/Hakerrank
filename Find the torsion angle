

import math

class Points(object):
    def __init__(self, x, y, z):
        self.x = x
        self.y = y
        self.z = z

    def __sub__(self, no):
        # Subtract coordinates to find vectors between points
        return Points(self.x - no.x, self.y - no.y, self.z - no.z)

    def dot(self, no):
        # Calculate dot product
        return self.x * no.x + self.y * no.y + self.z * no.z

    def cross(self, no):
        # Calculate cross product to find normal vectors
        return Points(self.y * no.z - self.z * no.y,
                      self.z * no.x - self.x * no.z,
                      self.x * no.y - self.y * no.x)

    def absolute(self):
        # Calculate magnitude (absolute value) of the vector
        return math.sqrt(self.x**2 + self.y**2 + self.z**2)




