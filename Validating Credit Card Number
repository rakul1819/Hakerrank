import re

def validate_card(card):
    # 1. Structure check: Starts with 4,5,6. 
    # Exactly 16 digits total. 
    # Groups of 4 separated by '-' or no hyphens at all.
    structure_pattern = r"^[456]\d{3}(-?\d{4}){3}$"
    
    if not re.match(structure_pattern, card):
        return "Invalid"
    
    # 2. Sequence check: Remove hyphens and look for 4+ consecutive identical digits
    clean_card = card.replace("-", "")
    if re.search(r"(\d)\1{3,}", clean_card):
        return "Invalid"
    
    return "Valid"

# Process input
for _ in range(int(input())):
    print(validate_card(input().strip()))
