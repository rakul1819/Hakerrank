
def merge_the_tools(s, k):
    # Iterate through the string in steps of k
    for i in range(0, len(s), k):
        substring = s[i:i + k]
        unique_chars = []
        seen = set()
        
        for char in substring:
            if char not in seen:
                unique_chars.append(char)
                seen.add(char)
        
        print("".join(unique_chars))


