def is_leap(year):
    leap = False
    
    # Check if divisible by 4
    if year % 4 == 0:
        # Check if it's a century year
        if year % 100 == 0:
            # Check if it's divisible by 400
            if year % 400 == 0:
                leap = True
            else:
                leap = False
        else:
            # Divisible by 4 but not 100
            leap = True
    
    return leap

