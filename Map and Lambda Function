cube = lambda x: x**3

def fibonacci(n):
    # Handle the first two numbers manually
    fib_list = [0, 1]
    
    if n == 0:
        return []
    elif n == 1:
        return [0]
    
    # Generate the rest of the sequence
    for i in range(2, n):
        fib_list.append(fib_list[-1] + fib_list[-2])
        
    return fib_list



