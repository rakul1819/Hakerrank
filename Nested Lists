if __name__ == '__main__':
    students = []
    for _ in range(int(input())):
        name = input()
        score = float(input())
        students.append([name, score])

    # 1. Extract all scores and find the unique second-lowest
    grades = sorted(set([s[1] for s in students]))
    second_lowest_grade = grades[1]

    # 2. Collect names of students with that grade
    low_scorers = [s[0] for s in students if s[1] == second_lowest_grade]

    # 3. Sort names alphabetically and print
    low_scorers.sort()
    for name in low_scorers:
        print(name)
