if __name__ == '__main__':
    # Read the main set A
    set_a = set(map(int, input().split()))
    
    # Read the number of other sets
    n = int(input())
    
    # Assume it is a strict superset until proven otherwise
    is_strict_superset = True
    
    for _ in range(n):
        # Read the next set
        other_set = set(map(int, input().split()))
        
        # Check if set_a is a strict superset of other_set
        # The '>' operator handles both conditions (subset + not equal)
        if not (set_a > other_set):
            is_strict_superset = False
            break
            
    print(is_strict_superset)
