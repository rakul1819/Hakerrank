def print_formatted(number):
    # Calculate the width of the binary representation of 'number'
    # bin(number) returns '0b...', so we use [2:] to slice off the prefix
    width = len(bin(number)[2:])

    for i in range(1, number + 1):
        # Convert i to each required format
        decimal = str(i)
        octal = oct(i)[2:]
        hex_val = hex(i)[2:].upper()
        binary = bin(i)[2:]

        # Print each value right-justified based on the binary width
        print(f"{decimal.rjust(width)} {octal.rjust(width)} {hex_val.rjust(width)} {binary.rjust(width)}")




