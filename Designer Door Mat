# Read input and split into N (height) and M (width)
N, M = map(int, input().split())

# 1. Top Half
# The pattern ".|." starts at 1 and increases by 2 each row (1, 3, 5...)
for i in range(1, N, 2):
    pattern = (".|." * i).center(M, "-")
    print(pattern)

# 2. Middle Line
print("WELCOME".center(M, "-"))

# 3. Bottom Half
# This is the top half reversed
for i in range(N-2, 0, -2):
    pattern = (".|." * i).center(M, "-")
    print(pattern)
