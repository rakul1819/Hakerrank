def minion_game(string):
    vowels = 'AEIOU'
    stuart_score = 0
    kevin_score = 0
    n = len(string)

    for i in range(n):

        score = n - i
        if string[i] in vowels:
            kevin_score += score
        else:
            stuart_score += score
    if stuart_score > kevin_score:
        print(f"Stuart {stuart_score}")
    elif kevin_score > stuart_score:
        print(f"Kevin {kevin_score}")
    else:
        print("Draw")


